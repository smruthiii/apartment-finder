# ─────────────────────────────────────────────
# Apartment Finder Agent — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API key — used for web search (free tier: 1,000 searches/month)
# Sign up at app.tavily.com → API Keys
TAVILY_API_KEY=tvly-...

# Gmail address that will SEND the alerts
GMAIL_ADDRESS=your-email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to create one:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification (required)
#   3. Search "App passwords" → create one → name it "apartment-finder"
#   4. Copy the 16-character password here (no spaces)
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxxxxxx

# Comma-separated list of recipient email addresses
# (you and your husband)
RECIPIENT_EMAILS=you@gmail.com,husband@email.com
