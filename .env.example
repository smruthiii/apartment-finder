# ─────────────────────────────────────────────
# Apartment Finder Agent — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API key — used for web search (free tier: 1,000 searches/month)
# Sign up at app.tavily.com → API Keys
TAVILY_API_KEY=tvly-...

# Resend API key — used to send email alerts (free tier: 3,000 emails/month)
# Sign up at resend.com → API Keys
RESEND_API_KEY=re_...

# Comma-separated list of recipient email addresses
# (you and your husband)
RECIPIENT_EMAILS=you@gmail.com,husband@email.com
